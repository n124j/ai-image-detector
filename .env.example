# ── Required ────────────────────────────────────────────────
# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ─────────────────────────────────────────────────
# Port to expose the app on (default: 6001)
FRONTEND_PORT=6001

# Restrict CORS to your domain in production (default: *)
ALLOWED_ORIGIN=*

# Node environment
NODE_ENV=production
